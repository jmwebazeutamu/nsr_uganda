# NSR MIS — production environment template (single-host, Apache-fronted).
#
# Copy to `.env` on the server and fill in the secrets. NEVER commit the
# real .env (it is gitignored). Generate the three secrets with:
#   DJANGO_SECRET_KEY : python -c "import secrets;print(secrets.token_urlsafe(64))"
#   NSR_NIN_PEPPER    : python -c "import secrets;print(secrets.token_urlsafe(48))"
#   NSR_DATA_KEY      : python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
#
# TLS + routing are handled by the host's Apache + certbot (a vhost for
# nsr-sris-dev.quasar.ug reverse-proxies to 127.0.0.1:8005). This stack
# does NOT run its own proxy. WhiteNoise serves static from gunicorn.

# --- image ------------------------------------------------------------------
NSR_IMAGE=ghcr.io/jmwebazeutamu/nsr_uganda:latest

# --- core Django ------------------------------------------------------------
DEBUG=False
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_64_char_secret
# Must include localhost: the container healthcheck curls localhost:8000/healthz
# and Apache proxies with Host: nsr-sris-dev.quasar.ug.
ALLOWED_HOSTS=nsr-sris-dev.quasar.ug,localhost,127.0.0.1
NSR_SECURE_SSL=True
CSRF_TRUSTED_ORIGINS=https://nsr-sris-dev.quasar.ug
NSR_WHITENOISE=True

# --- database (POSTGRES_* feed the db container; DATABASE_URL feeds Django —
#     they MUST agree) --------------------------------------------------------
POSTGRES_USER=nsr
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=nsr
DATABASE_URL=postgres://nsr:CHANGE_ME_strong_db_password@db:5432/nsr
# No read replica yet — point the analytics alias at the same database.
DATABASE_URL_ANALYTICS=postgres://nsr:CHANGE_ME_strong_db_password@db:5432/nsr

# --- crypto (security checks fail-closed when DEBUG=False without these) -----
NSR_NIN_PEPPER=CHANGE_ME_nin_pepper
NSR_DATA_KEY=CHANGE_ME_fernet_key

# --- Celery (real worker + beat in prod) ------------------------------------
CELERY_ENABLED=True
CELERY_TASK_ALWAYS_EAGER=False
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- feature flags ----------------------------------------------------------
# Consent stays OFF until DPO sign-off (per ADR-0024). Enable the surfaces
# that are production-ready.
CONSENT_MODULE_ENABLED=False
DQA_INTRA_HOUSEHOLD_ENABLED=True
DATA_EXPLORER_ENABLED=True
CHATBOT_ENABLED=False

# --- optional integrations --------------------------------------------------
# ANTHROPIC_API_KEY=
# DPO_EMAIL=dpo@mglsd.go.ug
# EMAIL_HOST=
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# SLACK_WEBHOOK_URL=
