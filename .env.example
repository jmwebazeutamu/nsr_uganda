# Copy to .env for local development. .env is gitignored.
#
# These dev-default values are the same ones apps.security.checks fails
# closed against, so you can switch DEBUG=False here to verify the
# production checks fire.

DEBUG=True
DJANGO_SECRET_KEY=dev-only-replace-before-deploy
ALLOWED_HOSTS=localhost,127.0.0.1

# sqlite fallback for the dev loop. For the docker-compose flow, use:
#   DATABASE_URL=postgres://nsr:nsr@db:5432/nsr
# DATABASE_URL=

# Column-level secrets for NIN encryption + join hashing. The values
# below are the public dev defaults — DO NOT use in production.
# Production deploys must read these from the NITA-U KMS or secrets
# manager (per ADR-0002 and DPIA §8).
NSR_NIN_PEPPER=dev-only-nin-pepper-replace-before-deploy
NSR_DATA_KEY=6kZf3vUYNDxBcLg3Vh-uYqOjQp4mEX0sIqAJ8u3OZk0=

# Email / SMTP. The app prefers SMTP automatically when host/user/
# password are present; otherwise it falls back to the console backend
# for dev/CI. To force a specific backend, set EMAIL_BACKEND
# explicitly. The quasar.ug relay is the same one the comms
# rental_project uses; the production password lives in the secrets
# manager, NEVER in this file.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=comms.quasar.ug
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=admin@quasar.ug
EMAIL_HOST_PASSWORD=replace-with-secret-from-secrets-manager
DEFAULT_FROM_EMAIL=NSR MIS <admin@quasar.ug>
